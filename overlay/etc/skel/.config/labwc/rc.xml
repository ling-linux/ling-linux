<?xml version="1.0"?>

<!--
  This is a very simple config file with many options missing. For a complete
  set of options with comments, see docs/rc.xml.all
-->

<labwc_config>

  <theme>
    <cornerRadius>8</cornerRadius>
    <font name="sans" size="10" />
  </theme>

  <keyboard>
    <default />
    <!-- Use a different terminal emulator -->
    <keybind key="W-Return">
      <action name="Execute" command="foot" />
    </keybind>
    <!-- Reconfigure labwc (reload configs without restart) -->
    <keybind key="W-R">
      <action name="Reconfigure" />
    </keybind>
    <!--
      Remove a previously defined keybind
      A shorter alternative is <keybind key="W-F4" />
    -->
    <keybind key="W-F4">
      <action name="None" />
    </keybind>
    <!-- Screenshots -->
    <keybind key="Print">
      <action name="Execute" command="sh -c 'grim -g &quot;$(slurp)&quot; ~/screenshot-$(date +%Y%m%d-%H%M%S).png'" />
    </keybind>
    <keybind key="W-Print">
      <action name="Execute" command="sh -c 'grim ~/screenshot-$(date +%Y%m%d-%H%M%S).png'" />
    </keybind>
  </keyboard>

  <mouse>
    <default />
    <!-- Show a custom menu on desktop right click -->
    <context name="Root">
      <mousebind button="Right" action="Press">
        <action name="ShowMenu" menu="some-custom-menu" />
      </mousebind>
    </context>
  </mouse>

</labwc_config>
